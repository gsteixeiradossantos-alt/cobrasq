{
  "manifest_version": 3,
  "name": "Cobrasq · Peticionador eproc/Projudi",
  "version": "0.10.0",
  "description": "Auto-preenche o peticionamento no eproc (TJPR, TJRS, TJSC e demais tribunais eproc) e no Projudi TJPR, a partir das petições preparadas no app Cobrasq. Para no botão de protocolar para revisão humana.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://painel.cobrasq.com.br/*",
    "https://*.jus.br/*",
    "https://jokbxzhcctcwnbhkhgru.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Peticionador eproc" },
  "content_scripts": [
    {
      "matches": ["https://painel.cobrasq.com.br/*"],
      "js": ["content-app.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.jus.br/*"],
      "js": ["selectors.js", "content-eproc.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://projudi.tjpr.jus.br/*"],
      "js": ["selectors.js", "content-projudi.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
