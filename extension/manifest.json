{
  "manifest_version": 3,
  "name": "Cobrasq · Peticionador eproc TJPR",
  "version": "0.1.0",
  "description": "Auto-preenche o peticionamento no eproc TJPR a partir das petições preparadas no app Cobrasq. Para no botão Protocolar para revisão humana.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://painel.cobrasq.com.br/*",
    "https://cobrasq-faturamento.vercel.app/*",
    "https://*.tjpr.jus.br/*",
    "https://jokbxzhcctcwnbhkhgru.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Peticionador eproc" },
  "content_scripts": [
    {
      "matches": ["https://painel.cobrasq.com.br/*", "https://cobrasq-faturamento.vercel.app/*"],
      "js": ["content-app.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.tjpr.jus.br/*"],
      "js": ["selectors.js", "content-eproc.js"],
      "run_at": "document_idle"
    }
  ]
}
